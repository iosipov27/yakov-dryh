{
  "name": "yakov-dryh",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node -e \"const fs=require('node:fs'); fs.rmSync('scripts',{recursive:true,force:true}); fs.rmSync('styles',{recursive:true,force:true});\" && npm run build:styles && tsc -p tsconfig.json",
    "build:styles": "sass src/styles/yakov-dryh.scss styles/yakov-dryh.css",
    "watch:styles": "sass --watch src/styles/yakov-dryh.scss:styles/yakov-dryh.css"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.2",
    "fvtt-types": "github:League-of-Foundry-Developers/foundry-vtt-types#main",
    "handlebars": "^4.7.8",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
