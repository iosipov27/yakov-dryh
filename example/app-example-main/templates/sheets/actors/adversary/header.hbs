<header class='adversary-header-sheet'>
    <line-div></line-div>
    <div class="name-row">
        <h1 class='input actor-name' contenteditable="plaintext-only" data-property="name" placeholder="{{localize "APP_EXAMPLE.GENERAL.actorName"}}">{{source.name}}</h1>
    </div>
    <div class="tags">
        <div class="tag">
            <span>
                {{localize (concat 'APP_EXAMPLE.GENERAL.Tiers.' source.system.tier)}}
            </span>
        </div>
        <div class="tag">
            <span>{{adversaryType}}</span>
        </div>
        {{#if (eq source.system.type 'horde')}}
            <div class="tag">
                <span>{{source.system.hordeHp}}</span>
                <span>/{{localize "APP_EXAMPLE.GENERAL.HitPoints.short"}}</span>
            </div>
        {{/if}}
        <div class="tag" data-tooltip="APP_EXAMPLE.UI.Tooltip.tokenSize">
            <i class="fa-solid fa-circle-user"></i>
            {{#unless (eq source.system.size 'custom')}}
                <span>{{localize (concat "APP_EXAMPLE.CONFIG.TokenSize." source.system.size)}}</span>
            {{else}}
                <span>{{source.prototypeToken.width}}x{{source.prototypeToken.height}}</span>
            {{/unless}}
        </div>
    </div>
    <line-div></line-div>
    <div class="adversary-info">
        <span class="description">
            <i>{{{description}}}</i>
        </span>
        <span class="motives-and-tatics">
            <b>{{localize 'APP_EXAMPLE.ACTORS.Adversary.FIELDS.motivesAndTactics.label'}}: </b>{{{source.system.motivesAndTactics}}}
        </span>
    </div>

    <div class="adversary-navigation">
        {{> 'systems/app-example/templates/sheets/global/tabs/tab-navigation.hbs'}}
        <button type="button" data-action="openSettings" data-tooltip-text="{{localize "APP_EXAMPLE.UI.Tooltip.openSheetSettings"}}">
            <i class="fa-solid fa-wrench"></i>
        </button>
    </div>
</header>