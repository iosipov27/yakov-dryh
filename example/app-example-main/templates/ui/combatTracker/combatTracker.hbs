<div class="combat-tracker">
    {{#if (gt this.spotlightRequests.length 0)}}
        {{> 'systems/app-example/templates/ui/combatTracker/combatTrackerSection.hbs' this title=(localize "APP_EXAMPLE.GENERAL.SpotlightRequests.plural") turns=this.spotlightRequests}}
    {{/if}}
    {{#if (gt this.characters.length 0)}}
        {{> 'systems/app-example/templates/ui/combatTracker/combatTrackerSection.hbs' this title=(localize "APP_EXAMPLE.GENERAL.Character.plural") turns=this.characters}}
    {{/if}}
    {{#if (gt this.adversaries.length 0)}}
        {{> 'systems/app-example/templates/ui/combatTracker/combatTrackerSection.hbs' this title=(localize "APP_EXAMPLE.GENERAL.Adversary.plural") turns=this.adversaries}}
    {{/if}}
</div>