<div class="yakov-dryh-resource-card">
  <div class="yakov-dryh-resource-card__header">
    <h4 class="m0">{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.Responses"}} ({{responseMax}})</h4>

    {{#if responseIsPlayMode}}
      <button
        class="yakov-dryh-resource-card__icon-action"
        type="button"
        data-yakov-dryh-response-action="edit"
        aria-label='{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Actions.EditResponses"}}'
        title='{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Actions.EditResponses"}}'
      >
        <i class="fa-solid fa-pen-to-square"></i>
      </button>
    {{/if}}

    {{#if responseIsEditMode}}
      <button
        class="yakov-dryh-resource-card__icon-action yakov-dryh-resource-card__icon-action--persistent"
        type="button"
        data-yakov-dryh-response-action="save"
        aria-label='{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Actions.SaveResponses"}}'
        title='{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Actions.SaveResponses"}}'
        {{#unless responseCanSave}}disabled{{/unless}}
      >
        <i class="fa-solid fa-floppy-disk"></i>
      </button>
    {{/if}}
  </div>

  {{#if responseIsPlayMode}}
    <div class="yakov-dryh-responses yakov-dryh-responses--play mt09">
      {{#each responsePlayRows}}
        <div class="yakov-dryh-response-line yakov-dryh-response-line--play">
          <span class="yakov-dryh-response-line__label">{{label}}:</span>
          <div class="yakov-dryh-response-line__checkboxes">
            {{#each checkboxes}}
              <input
                class="yakov-dryh-response-line__checkbox"
                type="checkbox"
                aria-label="{{label}}"
                data-yakov-dryh-response-toggle="{{index}}"
                {{#if checked}}checked{{/if}}
              >
            {{/each}}
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    <p class="yakov-dryh-copy m0 mt09">
      {{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.ResponsesHint"}}
    </p>

    <div class="yakov-dryh-responses mt09">
      {{#each responseAllocationRows}}
        <div class="yakov-dryh-response-line">
          <span class="yakov-dryh-response-line__label">{{label}}</span>
          <div class="yakov-dryh-response-line__checkboxes">
            {{#each checkboxes}}
              <input
                class="yakov-dryh-response-line__checkbox yakov-dryh-response-line__checkbox--static"
                type="checkbox"
                checked
                tabindex="-1"
                aria-label="{{label}}"
              >
            {{/each}}
          </div>
          {{#if ../responseCanAddMore}}
            <button
              class="yakov-dryh-button yakov-dryh-button--secondary yakov-dryh-button--compact yakov-dryh-response-line__add-button"
              type="button"
              data-yakov-dryh-response-add="{{type}}"
              aria-label="{{addLabel}}"
              title="{{addLabel}}"
            >
              +
            </button>
          {{/if}}
        </div>
      {{/each}}
    </div>

    <p class="yakov-dryh-copy m0 mt09">{{responseRemainingLabel}}</p>
  {{/if}}
</div>
