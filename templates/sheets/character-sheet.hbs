<section class="yakov-dryh-sheet-shell">
  <header class="yakov-dryh-header yakov-dryh-header--sheet">
    <div>
      <h2>{{actorName}}</h2>
    </div>
  </header>

  <div class="yakov-dryh-sheet-shell__columns">
    <div class="yakov-dryh-sheet-shell__column yakov-dryh-sheet-shell__column--story">
      <label class="yakov-dryh-field">
        <span>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.Name"}}</span>
        <input type="text" name="name" value="{{actorName}}">
      </label>

      <label class="yakov-dryh-field">
        <span>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.Concept"}}</span>
        <input type="text" name="system.concept" value="{{actorData.concept}}">
      </label>

      <div class="yakov-dryh-card-panel">
        <h3>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Sections.Talents"}}</h3>

        <label class="yakov-dryh-field">
          <span>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.ExhaustionTalent"}}</span>
          <input
            type="text"
            name="system.talents.exhaustion"
            value="{{actorData.talents.exhaustion}}"
          >
        </label>

        <label class="yakov-dryh-field">
          <span>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.MadnessTalent"}}</span>
          <input
            type="text"
            name="system.talents.madness"
            value="{{actorData.talents.madness}}"
          >
        </label>
      </div>

      <label class="yakov-dryh-field">
        <span>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.Scars"}}</span>
        <textarea data-yakov-dryh-field="scars">{{scarsText}}</textarea>
      </label>
    </div>

    <aside class="yakov-dryh-sheet-shell__column yakov-dryh-sheet-shell__column--sidebar">
      <div class="yakov-dryh-sheet-shell__header-side">
        <button
          class="yakov-dryh-button yakov-dryh-button--secondary"
          type="button"
          data-yakov-dryh-action="open-roll-dialog"
        >
          {{localize "YAKOV_DRYH.SHEETS.Actor.Character.Actions.Roll"}}
        </button>

        <div
          class="yakov-dryh-resource-card yakov-dryh-resource-card--stress yakov-dryh-resource-card--exhaustion"
          style="{{exhaustionCardStyle}}"
        >
          <div class="yakov-dryh-dice-picker">
            <div class="yakov-dryh-dice-picker__header">
              <h4>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.Exhaustion"}}</h4>
            </div>
            <div class="yakov-dryh-pip-track yakov-dryh-pip-track--exhaustion yakov-dryh-dice-picker__track">
              {{#each exhaustionPips}}
                {{#if action}}
                  <button
                    class="yakov-dryh-dice-picker__pip-control yakov-dryh-dice-picker__pip-control--{{action}}"
                    type="button"
                    data-yakov-dryh-pool-field="{{field}}"
                    data-yakov-dryh-pool-action="{{action}}"
                    {{#if tooltip}}title="{{tooltip}}" aria-label="{{tooltip}}"{{/if}}
                  >
                    <span class="yakov-dryh-pip {{#if filled}}yakov-dryh-pip--filled{{/if}}"></span>
                    <span class="yakov-dryh-dice-picker__action-icon yakov-dryh-dice-picker__action-icon--{{action}}">
                      <i class="{{iconClass}}"></i>
                    </span>
                  </button>
                {{else}}
                  <span class="yakov-dryh-dice-picker__pip-shell">
                    <span class="yakov-dryh-pip {{#if filled}}yakov-dryh-pip--filled{{/if}}"></span>
                  </span>
                {{/if}}
              {{/each}}
            </div>
          </div>
        </div>
      </div>

      <div class="yakov-dryh-resource-card">
        <div class="yakov-dryh-dice-picker">
          <div class="yakov-dryh-dice-picker__header">
            <h4>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.Discipline"}}</h4>
          </div>
          <div class="yakov-dryh-pip-track yakov-dryh-dice-picker__track">
            {{#each disciplinePips}}
              {{#if action}}
                <button
                  class="yakov-dryh-dice-picker__pip-control yakov-dryh-dice-picker__pip-control--{{action}}"
                  type="button"
                  data-yakov-dryh-pool-field="{{field}}"
                  data-yakov-dryh-pool-action="{{action}}"
                  {{#if tooltip}}title="{{tooltip}}" aria-label="{{tooltip}}"{{/if}}
                >
                  <span class="yakov-dryh-pip {{#if filled}}yakov-dryh-pip--filled{{/if}}"></span>
                  <span class="yakov-dryh-dice-picker__action-icon yakov-dryh-dice-picker__action-icon--{{action}}">
                    <i class="{{iconClass}}"></i>
                  </span>
                </button>
              {{else}}
                <span class="yakov-dryh-dice-picker__pip-shell">
                  <span class="yakov-dryh-pip {{#if filled}}yakov-dryh-pip--filled{{/if}}"></span>
                </span>
              {{/if}}
            {{/each}}
          </div>
        </div>
      </div>

      <div
        class="yakov-dryh-resource-card yakov-dryh-resource-card--stress yakov-dryh-resource-card--madness"
        style="{{madnessCardStyle}}"
      >
        <div class="yakov-dryh-dice-picker">
          <div class="yakov-dryh-dice-picker__header">
            <h4>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.PermanentMadness"}}</h4>
          </div>
          <div class="yakov-dryh-pip-track yakov-dryh-pip-track--madness yakov-dryh-dice-picker__track">
            {{#each madnessPips}}
              {{#if action}}
                <button
                  class="yakov-dryh-dice-picker__pip-control yakov-dryh-dice-picker__pip-control--{{action}}"
                  type="button"
                  data-yakov-dryh-pool-field="{{field}}"
                  data-yakov-dryh-pool-action="{{action}}"
                  {{#if tooltip}}title="{{tooltip}}" aria-label="{{tooltip}}"{{/if}}
                >
                  <span class="yakov-dryh-pip {{#if filled}}yakov-dryh-pip--filled{{/if}}"></span>
                  <span class="yakov-dryh-dice-picker__action-icon yakov-dryh-dice-picker__action-icon--{{action}}">
                    <i class="{{iconClass}}"></i>
                  </span>
                </button>
              {{else}}
                <span class="yakov-dryh-dice-picker__pip-shell">
                  <span class="yakov-dryh-pip {{#if filled}}yakov-dryh-pip--filled{{/if}}"></span>
                </span>
              {{/if}}
            {{/each}}
          </div>
        </div>
      </div>

      <div class="yakov-dryh-resource-card">
        <h4>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.Responses"}} ({{responseMax}})</h4>

        {{#if responseIsPlayMode}}
          <div class="yakov-dryh-responses yakov-dryh-responses--play mt09">
            {{#each responsePlayRows}}
              <div class="yakov-dryh-response-line yakov-dryh-response-line--play">
                <span class="yakov-dryh-response-line__label">{{label}}:</span>
                <div class="yakov-dryh-response-line__checkboxes">
                  {{#each checkboxes}}
                    <input
                      class="yakov-dryh-response-line__checkbox"
                      type="checkbox"
                      aria-label="{{label}}"
                      data-yakov-dryh-response-toggle="{{index}}"
                      {{#if checked}}checked{{/if}}
                    >
                  {{/each}}
                </div>
              </div>
            {{/each}}
          </div>

          <div class="yakov-dryh-actions mt12">
            <button
              class="yakov-dryh-button yakov-dryh-button--secondary"
              type="button"
              data-yakov-dryh-response-action="edit"
            >
              {{localize "YAKOV_DRYH.SHEETS.Actor.Character.Actions.EditResponses"}}
            </button>
          </div>
        {{else}}
          <p class="yakov-dryh-copy mt09">
            {{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.ResponsesHint"}}
          </p>

          <div class="yakov-dryh-responses mt09">
            {{#each responseAllocationRows}}
              <div class="yakov-dryh-response-line">
                <span class="yakov-dryh-response-line__label">{{label}}</span>
                <div class="yakov-dryh-response-line__checkboxes">
                  {{#each checkboxes}}
                    <input
                      class="yakov-dryh-response-line__checkbox yakov-dryh-response-line__checkbox--static"
                      type="checkbox"
                      checked
                      tabindex="-1"
                      aria-label="{{label}}"
                    >
                  {{/each}}
                </div>
                {{#if ../responseCanAddMore}}
                  <button
                    class="yakov-dryh-button yakov-dryh-button--secondary yakov-dryh-button--compact yakov-dryh-response-line__add-button"
                    type="button"
                    data-yakov-dryh-response-add="{{type}}"
                    aria-label="{{addLabel}}"
                    title="{{addLabel}}"
                  >
                    +
                  </button>
                {{/if}}
              </div>
            {{/each}}
          </div>

          <p class="yakov-dryh-copy mt09">{{responseRemainingLabel}}</p>

          {{#if responseIsEditMode}}
            <div class="yakov-dryh-actions mt12">
              <button
                class="yakov-dryh-button"
                type="button"
                data-yakov-dryh-response-action="save"
                {{#unless responseCanSave}}disabled{{/unless}}
              >
                {{localize "YAKOV_DRYH.SHEETS.Actor.Character.Actions.SaveResponses"}}
              </button>
            </div>
          {{/if}}
        {{/if}}
      </div>
    </aside>
  </div>
</section>
