<section class="yakov-dryh-sheet-shell">
  <header class="yakov-dryh-header yakov-dryh-header--sheet">
    <div>
      <p class="yakov-dryh-eyebrow">{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Eyebrow"}}</p>
      <h2>{{actorName}}</h2>
      <p class="yakov-dryh-subtitle">
        {{localize "YAKOV_DRYH.SHEETS.Actor.Character.ActorType"}}
        {{actorTypeLabel}}
      </p>
    </div>

    <div class="yakov-dryh-sheet-highlight yakov-dryh-sheet-highlight--exhaustion">
      <div class="yakov-dryh-sheet-pool yakov-dryh-sheet-pool--exhaustion">
        <div class="yakov-dryh-sheet-pool__header">
          <strong>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.Exhaustion"}}</strong>
          <span class="yakov-dryh-sheet-pool__value">
            {{actorData.exhaustion}} / {{exhaustionPipTotal}}
          </span>
        </div>
        <div class="yakov-dryh-pip-track yakov-dryh-pip-track--exhaustion yakov-dryh-sheet-pool__track">
          {{#each exhaustionPips}}
            {{#if action}}
              <button
                class="yakov-dryh-sheet-pool__pip-control yakov-dryh-sheet-pool__pip-control--{{action}}"
                type="button"
                data-yakov-dryh-pool-field="{{field}}"
                data-yakov-dryh-pool-action="{{action}}"
                {{#if tooltip}}title="{{tooltip}}" aria-label="{{tooltip}}"{{/if}}
              >
                <span class="yakov-dryh-pip {{#if filled}}yakov-dryh-pip--filled{{/if}}"></span>
                <span class="yakov-dryh-sheet-pool__action-icon yakov-dryh-sheet-pool__action-icon--{{action}}">
                  <i class="{{iconClass}}"></i>
                </span>
              </button>
            {{else}}
              <span class="yakov-dryh-sheet-pool__pip-shell">
                <span class="yakov-dryh-pip {{#if filled}}yakov-dryh-pip--filled{{/if}}"></span>
              </span>
            {{/if}}
          {{/each}}
        </div>
      </div>
      <div class="yakov-dryh-inline-actions">
        <button
          class="yakov-dryh-button yakov-dryh-button--secondary"
          type="button"
          data-yakov-dryh-action="open-roll-dialog"
        >
          {{localize "YAKOV_DRYH.SHEETS.Actor.Character.Actions.Roll"}}
        </button>
      </div>
    </div>
  </header>

  <div class="yakov-dryh-sheet-shell__columns">
    <div class="yakov-dryh-sheet-shell__column yakov-dryh-sheet-shell__column--story">
      <label class="yakov-dryh-field">
        <span>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.Name"}}</span>
        <input type="text" name="name" value="{{actorName}}">
      </label>

      <label class="yakov-dryh-field">
        <span>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.Concept"}}</span>
        <input type="text" name="system.concept" value="{{actorData.concept}}">
      </label>

      <div class="yakov-dryh-card-panel">
        <h3>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Sections.Talents"}}</h3>

        <label class="yakov-dryh-field">
          <span>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.ExhaustionTalent"}}</span>
          <input
            type="text"
            name="system.talents.exhaustion"
            value="{{actorData.talents.exhaustion}}"
          >
        </label>

        <label class="yakov-dryh-field">
          <span>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.MadnessTalent"}}</span>
          <input
            type="text"
            name="system.talents.madness"
            value="{{actorData.talents.madness}}"
          >
        </label>
      </div>

      <label class="yakov-dryh-field">
        <span>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.Scars"}}</span>
        <textarea data-yakov-dryh-field="scars">{{scarsText}}</textarea>
      </label>
    </div>

    <aside class="yakov-dryh-sheet-shell__column yakov-dryh-sheet-shell__column--sidebar">
      <div class="yakov-dryh-resource-card">
        <div class="yakov-dryh-sheet-pool">
          <div class="yakov-dryh-sheet-pool__header">
            <strong>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.Discipline"}}</strong>
            <span class="yakov-dryh-sheet-pool__value">
              {{actorData.discipline}} / {{disciplinePipTotal}}
            </span>
          </div>
          <div class="yakov-dryh-pip-track yakov-dryh-sheet-pool__track">
            {{#each disciplinePips}}
              {{#if action}}
                <button
                  class="yakov-dryh-sheet-pool__pip-control yakov-dryh-sheet-pool__pip-control--{{action}}"
                  type="button"
                  data-yakov-dryh-pool-field="{{field}}"
                  data-yakov-dryh-pool-action="{{action}}"
                  {{#if tooltip}}title="{{tooltip}}" aria-label="{{tooltip}}"{{/if}}
                >
                  <span class="yakov-dryh-pip {{#if filled}}yakov-dryh-pip--filled{{/if}}"></span>
                  <span class="yakov-dryh-sheet-pool__action-icon yakov-dryh-sheet-pool__action-icon--{{action}}">
                    <i class="{{iconClass}}"></i>
                  </span>
                </button>
              {{else}}
                <span class="yakov-dryh-sheet-pool__pip-shell">
                  <span class="yakov-dryh-pip {{#if filled}}yakov-dryh-pip--filled{{/if}}"></span>
                </span>
              {{/if}}
            {{/each}}
          </div>
        </div>
      </div>

      <div class="yakov-dryh-resource-card">
        <div class="yakov-dryh-sheet-pool yakov-dryh-sheet-pool--madness">
          <div class="yakov-dryh-sheet-pool__header">
            <strong>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.PermanentMadness"}}</strong>
            <span class="yakov-dryh-sheet-pool__value">
              {{actorData.madnessPermanent}} / {{madnessPipTotal}}
            </span>
          </div>
          <div class="yakov-dryh-pip-track yakov-dryh-pip-track--madness yakov-dryh-sheet-pool__track">
            {{#each madnessPips}}
              {{#if action}}
                <button
                  class="yakov-dryh-sheet-pool__pip-control yakov-dryh-sheet-pool__pip-control--{{action}}"
                  type="button"
                  data-yakov-dryh-pool-field="{{field}}"
                  data-yakov-dryh-pool-action="{{action}}"
                  {{#if tooltip}}title="{{tooltip}}" aria-label="{{tooltip}}"{{/if}}
                >
                  <span class="yakov-dryh-pip {{#if filled}}yakov-dryh-pip--filled{{/if}}"></span>
                  <span class="yakov-dryh-sheet-pool__action-icon yakov-dryh-sheet-pool__action-icon--{{action}}">
                    <i class="{{iconClass}}"></i>
                  </span>
                </button>
              {{else}}
                <span class="yakov-dryh-sheet-pool__pip-shell">
                  <span class="yakov-dryh-pip {{#if filled}}yakov-dryh-pip--filled{{/if}}"></span>
                </span>
              {{/if}}
            {{/each}}
          </div>
        </div>
      </div>

      <div class="yakov-dryh-resource-card">
        <h3>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.Responses"}}</h3>
        <p class="yakov-dryh-copy">
          {{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.ResponsesRemaining"}}
          {{responsesRemaining}} / {{actorData.responses.max}}
        </p>

        <label class="yakov-dryh-field">
          <span>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.Fight"}}</span>
          <input
            type="number"
            min="0"
            max="{{actorData.responses.max}}"
            step="1"
            value="{{actorData.responses.fight}}"
            data-yakov-dryh-response="fight"
          >
        </label>
        <div class="yakov-dryh-pip-track yakov-dryh-pip-track--response">
          {{#each responseFightPips}}
            <span class="yakov-dryh-pip {{#if filled}}yakov-dryh-pip--filled{{/if}}"></span>
          {{/each}}
        </div>

        <label class="yakov-dryh-field">
          <span>{{localize "YAKOV_DRYH.SHEETS.Actor.Character.Fields.Flight"}}</span>
          <input
            type="number"
            min="0"
            max="{{actorData.responses.max}}"
            step="1"
            value="{{actorData.responses.flight}}"
            data-yakov-dryh-response="flight"
          >
        </label>
        <div class="yakov-dryh-pip-track yakov-dryh-pip-track--response">
          {{#each responseFlightPips}}
            <span class="yakov-dryh-pip {{#if filled}}yakov-dryh-pip--filled{{/if}}"></span>
          {{/each}}
        </div>
      </div>
    </aside>
  </div>
</section>
