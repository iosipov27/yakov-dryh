<section class="yakov-dryh-dice-tray__shell">
  <section class="yakov-dryh-resource-tracker">
    <header
      class="yakov-dryh-resource-tracker__header"
      data-yakov-dryh-drag-handle
    >
      <p class="yakov-dryh-eyebrow yakov-dryh-resource-tracker__eyebrow m0">
        {{localize "YAKOV_DRYH.RESOURCES.Eyebrow"}}
      </p>
      <h3 class="m0">{{localize "YAKOV_DRYH.RESOURCES.Title"}}</h3>
    </header>

    <div class="yakov-dryh-resource-tracker__body">
      <section
        class="yakov-dryh-resource-tracker__pool yakov-dryh-resource-tracker__pool--hope"
        aria-label="{{localize "YAKOV_DRYH.RESOURCES.Hope"}}"
      >
        <div class="yakov-dryh-resource-tracker__controls">
          <button
            class="yakov-dryh-button yakov-dryh-button--secondary yakov-dryh-resource-tracker__adjuster"
            type="button"
            data-yakov-dryh-resource-pool="hope"
            data-yakov-dryh-resource-delta="-1"
            {{#unless canEdit}}disabled{{/unless}}
          >
            -
          </button>

          <div class="yakov-dryh-resource-tracker__coin-wrap">
            <div class="yakov-dryh-resource-tracker__coin">
              <span class="yakov-dryh-resource-tracker__value">{{hope}}</span>
            </div>
            <div class="yakov-dryh-resource-tracker__meta">
              <p class="yakov-dryh-resource-tracker__caption m0">
                {{localize "YAKOV_DRYH.RESOURCES.Hope"}}
              </p>
              {{#if hasPendingHope}}
                <p class="yakov-dryh-copy yakov-dryh-resource-tracker__note m0">
                  +{{pendingHope}} {{localize "YAKOV_DRYH.RESOURCES.NextScene"}}
                </p>
              {{/if}}
            </div>
          </div>

          <button
            class="yakov-dryh-button yakov-dryh-resource-tracker__adjuster"
            type="button"
            data-yakov-dryh-resource-pool="hope"
            data-yakov-dryh-resource-delta="1"
            {{#unless canEdit}}disabled{{/unless}}
          >
            +
          </button>
        </div>
      </section>

      <section
        class="yakov-dryh-resource-tracker__pool yakov-dryh-resource-tracker__pool--despair"
        aria-label="{{localize "YAKOV_DRYH.RESOURCES.Despair"}}"
      >
        <div class="yakov-dryh-resource-tracker__controls">
          <button
            class="yakov-dryh-button yakov-dryh-button--secondary yakov-dryh-resource-tracker__adjuster"
            type="button"
            data-yakov-dryh-resource-pool="despair"
            data-yakov-dryh-resource-delta="-1"
            {{#unless canEdit}}disabled{{/unless}}
          >
            -
          </button>

          <div class="yakov-dryh-resource-tracker__coin-wrap">
            <div class="yakov-dryh-resource-tracker__coin">
              <span class="yakov-dryh-resource-tracker__value">{{despair}}</span>
            </div>
            <div class="yakov-dryh-resource-tracker__meta">
              <p class="yakov-dryh-resource-tracker__caption m0">
                {{localize "YAKOV_DRYH.RESOURCES.Despair"}}
              </p>
            </div>
          </div>

          <button
            class="yakov-dryh-button yakov-dryh-resource-tracker__adjuster"
            type="button"
            data-yakov-dryh-resource-pool="despair"
            data-yakov-dryh-resource-delta="1"
            {{#unless canEdit}}disabled{{/unless}}
          >
            +
          </button>
        </div>
      </section>
    </div>

    <footer class="yakov-dryh-resource-tracker__footer">
      <button
        class="yakov-dryh-button yakov-dryh-button--secondary yakov-dryh-resource-tracker__scene-button"
        type="button"
        data-yakov-dryh-resource-action="end-scene"
        {{#unless hasPendingHope}}disabled{{/unless}}
      >
        {{localize "YAKOV_DRYH.RESOURCES.EndScene"}}
      </button>
    </footer>

    {{#unless canEdit}}
      <p class="yakov-dryh-copy yakov-dryh-resource-tracker__read-only m0">
        {{localize "YAKOV_DRYH.RESOURCES.ReadOnly"}}
      </p>
    {{/unless}}
  </section>

  <section class="yakov-dryh-dice-tray__panel">


    {{#if hasActor}}
      <div class="yakov-dryh-dice-tray__pools">
        {{#each poolSummaries}}
          <section class="yakov-dryh-card-panel yakov-dryh-dice-tray__pool yakov-dryh-dice-tray__pool--{{key}}">
            <div class="yakov-dryh-dice-picker">
              <div class="yakov-dryh-dice-picker__header">
                <span>{{label}}</span>
              </div>
              <div class="yakov-dryh-pip-track yakov-dryh-dice-tray__track mt065{{#if trackClass}} {{trackClass}}{{/if}}">
                {{#if empty}}
                  <span class="yakov-dryh-copy yakov-dryh-dice-tray__empty m0">-</span>
                {{/if}}
                {{#each pips}}
                  {{#if removable}}
                    <button
                      class="yakov-dryh-dice-picker__pip-control yakov-dryh-dice-picker__pip-control--decrease{{#if hidden}} yakov-dryh-dice-picker__pip-slot--hidden{{/if}}"
                      type="button"
                      data-yakov-dryh-tray-pool="{{../key}}"
                      data-yakov-dryh-tray-delta="-1"
                      {{#if tooltip}}title="{{tooltip}}" aria-label="{{tooltip}}"{{/if}}
                    >
                      <span class="yakov-dryh-pip yakov-dryh-pip--filled"></span>
                      <span class="yakov-dryh-dice-picker__action-icon yakov-dryh-dice-picker__action-icon--decrease">
                        <i class="fa-solid fa-trash-can"></i>
                      </span>
                    </button>
                  {{else}}
                    <span class="yakov-dryh-dice-picker__pip-shell{{#if hidden}} yakov-dryh-dice-picker__pip-slot--hidden{{/if}}">
                      <span class="yakov-dryh-pip yakov-dryh-pip--filled"></span>
                    </span>
                  {{/if}}
                {{/each}}
              </div>
            </div>
          </section>
        {{/each}}
      </div>

      <div class="yakov-dryh-dice-tray__palette">
        <p class="yakov-dryh-copy yakov-dryh-dice-tray__palette-label m0">
          {{localize "YAKOV_DRYH.TRAY.AddDie"}}
        </p>

        <div class="yakov-dryh-dice-tray__palette-buttons">
          {{#each paletteButtons}}
            <button
              class="yakov-dryh-dice-tray__palette-button {{modifierClass}}"
              type="button"
              data-yakov-dryh-tray-pool="{{key}}"
              data-yakov-dryh-tray-delta="1"
              title="{{label}}"
              aria-label="{{label}}"
              {{#if disabled}}disabled{{/if}}
            >
              <span class="yakov-dryh-pip yakov-dryh-pip--filled"></span>
            </button>
          {{/each}}
        </div>
      </div>

      <footer class="yakov-dryh-dice-tray__actions mt15">
        {{#if canRoll}}
          <button
            class="yakov-dryh-button"
            type="button"
            data-yakov-dryh-tray-action="roll"
          >
            {{localize "YAKOV_DRYH.TRAY.Roll"}}
          </button>
        {{/if}}
      </footer>
    {{else}}
      <div class="yakov-dryh-dice-tray__empty-state">
        <p class="yakov-dryh-copy m0">{{localize "YAKOV_DRYH.TRAY.EmptyState"}}</p>
      </div>
    {{/if}}
  </section>
</section>
