<section class="yakov-dryh-resource-tracker">
  <header
    class="yakov-dryh-resource-tracker__header"
    data-yakov-dryh-drag-handle
  >
    <p class="yakov-dryh-eyebrow m0 mb035">{{localize "YAKOV_DRYH.RESOURCES.Eyebrow"}}</p>
    <h3 class="m0">{{localize "YAKOV_DRYH.RESOURCES.Title"}}</h3>
  </header>

  <div class="yakov-dryh-resource-tracker__rows">
    <section class="yakov-dryh-resource-tracker__row yakov-dryh-resource-tracker__row--hope">
      <div>
        <strong>{{localize "YAKOV_DRYH.RESOURCES.Hope"}}</strong>
        <div class="yakov-dryh-resource-tracker__values mt02">
          <p class="yakov-dryh-copy yakov-dryh-resource-tracker__value m0">{{hope}}</p>
          {{#if hasPendingHope}}
            <p class="yakov-dryh-copy yakov-dryh-resource-tracker__value yakov-dryh-resource-tracker__value--pending m0">
              {{pendingHope}}
            </p>
          {{/if}}
        </div>
      </div>

      <div class="yakov-dryh-resource-tracker__actions">
        <div class="yakov-dryh-inline-actions">
          <button
            class="yakov-dryh-button yakov-dryh-button--secondary yakov-dryh-button--compact"
            type="button"
            data-yakov-dryh-resource-pool="hope"
            data-yakov-dryh-resource-delta="-1"
          >
            -
          </button>
          <button
            class="yakov-dryh-button yakov-dryh-button--compact"
            type="button"
            data-yakov-dryh-resource-pool="hope"
            data-yakov-dryh-resource-delta="1"
          >
            +
          </button>
        </div>
        <button
          class="yakov-dryh-button yakov-dryh-button--secondary yakov-dryh-button--compact"
          type="button"
          data-yakov-dryh-resource-action="end-scene"
          {{#unless hasPendingHope}}disabled{{/unless}}
        >
          {{localize "YAKOV_DRYH.RESOURCES.EndScene"}}
        </button>
      </div>
    </section>

    <section class="yakov-dryh-resource-tracker__row yakov-dryh-resource-tracker__row--despair">
      <div>
        <strong>{{localize "YAKOV_DRYH.RESOURCES.Despair"}}</strong>
        <p class="yakov-dryh-copy m0 mt02">{{despair}}</p>
      </div>

      <div class="yakov-dryh-inline-actions">
        <button
          class="yakov-dryh-button yakov-dryh-button--secondary yakov-dryh-button--compact"
          type="button"
          data-yakov-dryh-resource-pool="despair"
          data-yakov-dryh-resource-delta="-1"
        >
          -
        </button>
        <button
          class="yakov-dryh-button yakov-dryh-button--compact"
          type="button"
          data-yakov-dryh-resource-pool="despair"
          data-yakov-dryh-resource-delta="1"
        >
          +
        </button>
      </div>
    </section>
  </div>

  {{#unless canEdit}}
    <p class="yakov-dryh-copy m0 mt035">{{localize "YAKOV_DRYH.RESOURCES.ReadOnly"}}</p>
  {{/unless}}
</section>
