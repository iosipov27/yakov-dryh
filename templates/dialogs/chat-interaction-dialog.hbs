<section class="yakov-dryh-dialog-shell">
  <header class="yakov-dryh-header">
    <div>
      <p class="yakov-dryh-eyebrow m0 mb035">Composition Root</p>
      <h2 class="m0">Chat interaction controller</h2>
      <p class="yakov-dryh-subtitle m0 mt035">Message
        {{messageId}}
        is synchronized with the interactive chat card.</p>
    </div>

    <span
      class="yakov-dryh-status yakov-dryh-status--{{card.status}}"
    >{{statusLabel}}</span>
  </header>

  <div class="yakov-dryh-dialog-grid">
    <label class="yakov-dryh-field">
      <span>Summary</span>
      <input type="text" name="summary" value="{{card.summary}}" />
    </label>

    <label class="yakov-dryh-field">
      <span>Detail</span>
      <textarea name="detail">{{card.detail}}</textarea>
    </label>

    <label class="yakov-dryh-field">
      <span>Status</span>
      <select name="status">
        {{#each statusOptions}}
          {{#if selected}}
            <option value="{{value}}" selected>{{label}}</option>
          {{else}}
            <option value="{{value}}">{{label}}</option>
          {{/if}}
        {{/each}}
      </select>
    </label>

    <div class="yakov-dryh-card-panel">
      <h4 class="m0">Interaction scope</h4>
      <p class="yakov-dryh-copy m0 mt035">
        This popup is the first orchestration surface for complex edits that
        need to push changes back into chat.
      </p>
    </div>
  </div>

  <footer class="yakov-dryh-actions mt12">
    <button
      class="yakov-dryh-button"
      type="button"
      data-yakov-dryh-action="apply-updates"
    >
      Apply to chat card
    </button>
    <button
      class="yakov-dryh-button yakov-dryh-button--secondary"
      type="button"
      data-yakov-dryh-action="advance-status"
    >
      Cycle status
    </button>
  </footer>
</section>
