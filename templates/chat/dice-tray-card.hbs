<article class="yakov-dryh-chat-card yakov-dryh-dice-tray-card">
  <section class="yakov-dryh-dice-tray__shell">
    <section class="yakov-dryh-dice-tray__panel">


      <div class="yakov-dryh-dice-tray__pools">
        {{#each poolSummaries}}
          <section class="yakov-dryh-card-panel yakov-dryh-dice-tray__pool yakov-dryh-dice-tray__pool--{{key}}">
            <div class="yakov-dryh-dice-picker">
              <div class="yakov-dryh-dice-picker__header">
                <span>{{label}}</span>
                <div class="yakov-dryh-inline-actions yakov-dryh-dice-tray__pool-controls">
                  <button
                    class="yakov-dryh-button yakov-dryh-button--secondary yakov-dryh-button--compact"
                    type="button"
                    data-yakov-dryh-tray-card-pool="{{key}}"
                    data-yakov-dryh-tray-card-delta="-1"
                    title="{{controls.decreaseLabel}}"
                    aria-label="{{controls.decreaseLabel}}"
                    {{#unless controls.canDecrease}}disabled{{/unless}}
                  >
                    -
                  </button>
                  <button
                    class="yakov-dryh-button yakov-dryh-button--compact"
                    type="button"
                    data-yakov-dryh-tray-card-pool="{{key}}"
                    data-yakov-dryh-tray-card-delta="1"
                    title="{{controls.increaseLabel}}"
                    aria-label="{{controls.increaseLabel}}"
                    {{#unless controls.canIncrease}}disabled{{/unless}}
                  >
                    +
                  </button>
                </div>
              </div>
              <div class="yakov-dryh-pip-track yakov-dryh-dice-tray__track mt065{{#if trackClass}} {{trackClass}}{{/if}}">
                {{#if empty}}
                  <span class="yakov-dryh-copy yakov-dryh-dice-tray__empty">-</span>
                {{/if}}
                {{#each pips}}
                  <span class="yakov-dryh-dice-picker__pip-shell{{#if hidden}} yakov-dryh-dice-picker__pip-slot--hidden{{/if}}">
                    <span class="yakov-dryh-pip yakov-dryh-pip--filled"></span>
                  </span>
                {{/each}}
              </div>
            </div>
          </section>
        {{/each}}
      </div>

      <footer class="yakov-dryh-dice-tray__actions mt15">
        <button
          class="yakov-dryh-button"
          type="button"
          data-yakov-dryh-tray-card-action="roll"
          {{#if rollDisabled}}disabled{{/if}}
        >
          {{localize "YAKOV_DRYH.TRAY.Roll"}}
        </button>
      </footer>
    </section>
  </section>
</article>
