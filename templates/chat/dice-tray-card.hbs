<article class="yakov-dryh-chat-card yakov-dryh-dice-tray-card">
  <section class="yakov-dryh-dice-tray__shell">
    <section class="yakov-dryh-dice-tray__panel">
      <header class="yakov-dryh-dice-tray__panel-header">
        <div>
          <p class="yakov-dryh-eyebrow m0 mb035">{{localize "YAKOV_DRYH.TRAY.Eyebrow"}}</p>
        </div>
        {{#if statusLabel}}
          <p class="yakov-dryh-copy yakov-dryh-dice-tray__status m0">{{statusLabel}}</p>
        {{/if}}
      </header>

      <div class="yakov-dryh-dice-tray__pools">
        {{#each poolSummaries}}
          <section class="yakov-dryh-card-panel yakov-dryh-dice-tray__pool">
            <div class="yakov-dryh-dice-picker">
              <div class="yakov-dryh-dice-picker__header">
                <strong>{{label}}</strong>
              </div>
              <div class="yakov-dryh-pip-track yakov-dryh-dice-tray__track mt065{{#if trackClass}} {{trackClass}}{{/if}}">
                {{#if empty}}
                  <span class="yakov-dryh-copy yakov-dryh-dice-tray__empty">-</span>
                {{else}}
                  {{#each pips}}
                    {{#if removable}}
                      <button
                        class="yakov-dryh-dice-picker__pip-control yakov-dryh-dice-picker__pip-control--decrease"
                        type="button"
                        data-yakov-dryh-tray-card-pool="{{../key}}"
                        data-yakov-dryh-tray-card-delta="-1"
                        {{#if tooltip}}title="{{tooltip}}" aria-label="{{tooltip}}"{{/if}}
                      >
                        <span class="yakov-dryh-pip yakov-dryh-pip--filled"></span>
                        <span class="yakov-dryh-dice-picker__action-icon yakov-dryh-dice-picker__action-icon--decrease">
                          <i class="fa-solid fa-trash-can"></i>
                        </span>
                      </button>
                    {{else}}
                      <span class="yakov-dryh-dice-picker__pip-shell">
                        <span class="yakov-dryh-pip yakov-dryh-pip--filled"></span>
                      </span>
                    {{/if}}
                  {{/each}}
                {{/if}}
              </div>
            </div>
          </section>
        {{/each}}
      </div>

      <div class="yakov-dryh-dice-tray__palette">
        <p class="yakov-dryh-copy yakov-dryh-dice-tray__palette-label m0">
          {{localize "YAKOV_DRYH.TRAY.AddDie"}}
        </p>

        <div class="yakov-dryh-dice-tray__palette-buttons">
          {{#each paletteButtons}}
            <button
              class="yakov-dryh-dice-tray__palette-button {{modifierClass}}"
              type="button"
              data-yakov-dryh-tray-card-pool="{{key}}"
              data-yakov-dryh-tray-card-delta="1"
              title="{{label}}"
              aria-label="{{label}}"
              {{#if disabled}}disabled{{/if}}
            >
              <span class="yakov-dryh-pip yakov-dryh-pip--filled"></span>
            </button>
          {{/each}}
        </div>
      </div>

      <footer class="yakov-dryh-dice-tray__actions">
        <button
          class="yakov-dryh-button"
          type="button"
          data-yakov-dryh-tray-card-action="roll"
          {{#if rollDisabled}}disabled{{/if}}
        >
          {{localize "YAKOV_DRYH.TRAY.Roll"}}
        </button>
      </footer>
    </section>
  </section>
</article>
