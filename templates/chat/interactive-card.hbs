<article class="yakov-dryh-chat-card">
  <header class="yakov-dryh-header">
    <div>
      <p class="yakov-dryh-eyebrow m0 mb035">Yakov Dryh</p>
      <h3 class="m0">Interactive chat workflow</h3>
      <p class="yakov-dryh-subtitle m0 mt035">{{card.summary}}</p>
    </div>

    <span
      class="yakov-dryh-status yakov-dryh-status--{{card.status}}"
    >{{statusLabel}}</span>
  </header>

  <div class="yakov-dryh-chat-card__body">
    {{#if card.detail}}
      <p class="yakov-dryh-chat-card__detail m0">{{card.detail}}</p>
    {{/if}}

    <dl class="yakov-dryh-chat-card__meta">
      <div>
        <dt>Actor</dt>
        <dd>{{#if hasActor}}{{card.actorName}}{{else}}Detached card{{/if}}</dd>
      </div>
      <div>
        <dt>Updated</dt>
        <dd>{{lastUpdated}}</dd>
      </div>
    </dl>
  </div>

  <footer class="yakov-dryh-actions">
    {{#if canOpenDialog}}
      <button
        class="yakov-dryh-button"
        type="button"
        data-yakov-dryh-action="open-dialog"
      >
        Open interaction window
      </button>
    {{/if}}

    {{#if canAdvanceStatus}}
      <button
        class="yakov-dryh-button yakov-dryh-button--secondary"
        type="button"
        data-yakov-dryh-action="advance-status"
      >
        Advance status
      </button>
    {{/if}}
  </footer>
</article>