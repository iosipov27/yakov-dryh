<article class="yakov-dryh-chat-card yakov-dryh-roll-card {{#if isFinal}}yakov-dryh-roll-card--final{{/if}}">
  <header class="yakov-dryh-header">
    <div>
      <h3>{{stageLabel}}</h3>
      <p class="yakov-dryh-subtitle">{{actorName}}</p>
    </div>

    {{#if showOutcome}}
      <span class="yakov-dryh-status yakov-dryh-status--{{rollResult.outcome}}">{{outcomeLabel}}</span>
    {{/if}}
  </header>

  <div class="yakov-dryh-chat-card__body">
    {{#if showOutcome}}
      <p class="yakov-dryh-roll-card__summary">
        {{localize "YAKOV_DRYH.ROLL.Chat.Successes"}}
        {{rollResult.successes.player}}
        vs
        {{rollResult.successes.pain}}
        <i class="fa-solid fa-arrow-right yakov-dryh-roll-card__arrow" aria-hidden="true"></i>
        <strong>{{outcomeLabel}}</strong>
      </p>
    {{/if}}

    <div class="yakov-dryh-roll-card__pools">
      {{#each poolSummaries}}
        <section class="yakov-dryh-roll-pool {{cssClass}}">
          <div class="yakov-dryh-roll-pool__content">
            <strong>{{label}}</strong>
            <div class="yakov-dryh-roll-pool__result">
              {{#if hasDice}}
                <div class="yakov-dryh-roll-pool__dice" aria-label="{{label}}">
                  {{#each dice}}
                    <span class="yakov-dryh-roll-pool__die-shell">
                      <img
                        class="yakov-dryh-roll-pool__die-icon"
                        src="{{src}}"
                        alt="{{alt}}"
                        width="28"
                        height="28"
                      >
                    </span>
                  {{/each}}
                </div>
              {{else}}
                <span class="yakov-dryh-copy">-</span>
              {{/if}}
              <span class="yakov-dryh-roll-pool__successes">
                <i class="fa-solid fa-arrow-right yakov-dryh-roll-pool__arrow" aria-hidden="true"></i>
                <span class="yakov-dryh-roll-pool__successes-count">{{successes}}</span>
              </span>
            </div>
          </div>

          {{#if ../showAdjustments}}
            <div class="yakov-dryh-inline-actions">
              <button
                class="yakov-dryh-button yakov-dryh-button--secondary yakov-dryh-button--compact"
                type="button"
                data-yakov-dryh-roll-action="add6"
                data-target-pool="{{key}}"
                {{#unless ../canAffordAdjustment}}disabled{{/unless}}
              >
                +6
              </button>
              <button
                class="yakov-dryh-button yakov-dryh-button--secondary yakov-dryh-button--compact"
                type="button"
                data-yakov-dryh-roll-action="remove6"
                data-target-pool="{{key}}"
                {{#unless ../canAffordAdjustment}}disabled{{else}}{{#unless hasSix}}disabled{{/unless}}{{/unless}}
              >
                -6
              </button>
            </div>
          {{/if}}
        </section>
      {{/each}}
    </div>

    {{#if showDominant}}
      <p class="yakov-dryh-roll-card__dominant">
        <strong>{{localize "YAKOV_DRYH.ROLL.Chat.Dominant"}}</strong>
        {{dominantLabel}}
      </p>
    {{/if}}

    {{#if hasEffectText}}
      <div class="yakov-dryh-chat-card__detail">
        <strong>{{localize "YAKOV_DRYH.ROLL.Chat.Effect"}}</strong>
        {{#if dominantEffectText}}
          <p>{{dominantEffectText}}</p>
        {{/if}}
        {{#if failureEffectText}}
          <p>{{failureEffectText}}</p>
        {{/if}}
        {{#if snapEffectText}}
          <div class="yakov-dryh-roll-card__snap-effect">
            <strong>{{localize "YAKOV_DRYH.ROLL.Chat.Snap"}}</strong>
            <p>{{snapEffectText}}</p>
          </div>
        {{/if}}
      </div>
    {{/if}}

    {{#if isResolved}}
      {{#if finalMessageId}}
        <p class="yakov-dryh-copy">{{localize "YAKOV_DRYH.ROLL.Chat.Finalized"}}</p>
      {{/if}}
    {{/if}}
  </div>

  {{#if canRollPain}}
    <footer class="yakov-dryh-actions mt12">
      <button
        class="yakov-dryh-button"
        type="button"
        data-yakov-dryh-roll-action="roll-pain"
      >
        {{localize "YAKOV_DRYH.ROLL.Chat.RollPain"}}
      </button>
      {{#if showPainRollWaiting}}
        <p
          class="yakov-dryh-copy"
          data-yakov-dryh-roll-waiting
          hidden
        >
          {{waitingForPainLabel}}
        </p>
      {{/if}}
    </footer>
  {{/if}}

  {{#if hasPlayerActionButtons}}
    <footer class="yakov-dryh-roll-card__resolution">
      {{#if playerActionPrompt}}
        <p class="yakov-dryh-copy yakov-dryh-roll-card__resolution-copy">
          {{playerActionPrompt}}
        </p>
      {{/if}}
      <div class="yakov-dryh-actions mt12">
        {{#each playerActionButtons}}
          <button
            class="yakov-dryh-button yakov-dryh-button--secondary"
            type="button"
            data-yakov-dryh-roll-action="{{type}}"
          >
            {{label}}
          </button>
        {{/each}}
      </div>
    </footer>
  {{/if}}

  {{#if canFinalize}}
    <footer class="yakov-dryh-actions mt12">
      <button
        class="yakov-dryh-button"
        type="button"
        data-yakov-dryh-roll-action="finalize"
      >
        {{localize "YAKOV_DRYH.ROLL.Chat.Finalize"}}
      </button>
    </footer>
  {{/if}}

  {{#if hasDominantResolutionButtons}}
    <footer class="yakov-dryh-roll-card__resolution">
      {{#if dominantResolutionPrompt}}
        <p class="yakov-dryh-copy yakov-dryh-roll-card__resolution-copy">
          {{dominantResolutionPrompt}}
        </p>
      {{/if}}
      <div class="yakov-dryh-actions mt12">
        {{#each dominantResolutionButtons}}
          <button
            class="yakov-dryh-button yakov-dryh-button--secondary"
            type="button"
            data-yakov-dryh-roll-action="resolve-dominant"
            data-dominant-action="{{type}}"
            {{#if responseType}}data-response-type="{{responseType}}"{{/if}}
          >
            {{label}}
          </button>
        {{/each}}
      </div>
    </footer>
  {{/if}}

  {{#if hasFailureResolutionButtons}}
    <footer class="yakov-dryh-roll-card__resolution">
      {{#if failureResolutionPrompt}}
        <p class="yakov-dryh-copy yakov-dryh-roll-card__resolution-copy">
          {{failureResolutionPrompt}}
        </p>
      {{/if}}
      <div class="yakov-dryh-actions mt12">
        {{#each failureResolutionButtons}}
          <button
            class="yakov-dryh-button yakov-dryh-button--secondary"
            type="button"
            data-yakov-dryh-roll-action="resolve-failure"
            data-failure-action="{{type}}"
            {{#if responseType}}data-response-type="{{responseType}}"{{/if}}
          >
            {{label}}
          </button>
        {{/each}}
      </div>
    </footer>
  {{/if}}
</article>
